<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Idem Website</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background: #f4f4f4;
        }

        header {
            background: #111;
            color: white;
            padding: 15px;
            text-align: center;
        }

        nav {
            background: #333;
            padding: 10px;
            text-align: center;
        }

        nav a {
            color: white;
            margin: 10px;
            text-decoration: none;
            font-weight: bold;
        }

        nav a:hover {
            color: yellow;
        }

        .hero {
            height: 300px;
            background: linear-gradient(to right, #ff4b2b, #ff416c);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 30px;
        }

        .container {
            padding: 20px;
        }

        .card {
            background: white;
            padding: 15px;
            margin: 10px;
            display: inline-block;
            width: 30%;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            border-radius: 10px;
        }

        .card h3 {
            margin-bottom: 10px;
        }

        footer {
            background: #111;
            color: white;
            text-align: center;
            padding: 10px;
            margin-top: 20px;
        }

        @media(max-width: 768px) {
            .card {
                width: 100%;
            }
        }
    </style>
</head>
<body>

<header>
    <h1>Idem Website</h1>
    <p>Welcome to my website</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">Products</a>
    <a href="#">Contact</a>
</nav>

<div class="hero">
    <h2>Best Online Store</h2>
</div>

<div class="container">
    <div class="card">
        <h3>Shoes</h3>
        <p>Best quality shoes available.</p>
    </div>

    <div class="card">
        <h3>Jackets</h3>
        <p>Stylish jackets for winter.</p>
    </div>

    <div class="card">
        <h3>Accessories</h3>
        <p>All fashion accessories here.</p>
    </div>
</div>

<footer>
    <p>© 2026 Idem Website | All Rights Reserved</p>
</footer>

</body>
</html>
